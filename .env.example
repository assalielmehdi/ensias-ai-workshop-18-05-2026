# LLM provider mode: "mock" | "openrouter" | "openai"
# - mock:       deterministic stub, no API key needed (great for tests / first run)
# - openrouter: any model on OpenRouter (default)
# - openai:     any OpenAI-compatible endpoint (set LLM_BASE_URL accordingly)
LLM_MODE=openrouter

# API key for the chosen provider. Ignored in mock mode.
LLM_API_KEY=sk-or-v1-replace-me

# Base URL of the OpenAI-compatible API.
LLM_BASE_URL=https://openrouter.ai/api/v1

# Default model. Pick whatever your provider supports.
LLM_MODEL=deepseek/deepseek-v3.2

# Sampling temperature for the LLM.
LLM_TEMPERATURE=0.2

# Hard cap on agent loop iterations (prevents runaway tool-calling).
AGENT_MAX_ITERATIONS=6

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
